{
  "name": "ui-designer",
  "version": "0.1.0",
  "private": true,
  "description": "XAML-inspired UI framework and designer targeting WebGPU",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:playground": "npm run dev --workspace @ui-designer/playground",
    "dev:designer": "npm run dev --workspace @ui-designer/designer",
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test:xaml": "npm run build && node scripts/test-xaml-fixtures.mjs"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "preact": "^10.26.9"
  },
  "devDependencies": {
    "@types/node": "^24.9.0",
    "@webgpu/types": "^0.1.64",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
