<Canvas xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Button>
    <Button.Template>
      <ControlTemplate>
        <Grid>
          <TextBlock x:Name="TemplateLabel" Text="Template label" />
          <Border>
            <Border.Child>{x:Reference TemplateLabel}</Border.Child>
          </Border>
        </Grid>
      </ControlTemplate>
    </Button.Template>
  </Button>
</Canvas>
