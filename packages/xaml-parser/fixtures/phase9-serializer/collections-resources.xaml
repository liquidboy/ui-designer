<Canvas xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Canvas.Resources>
    <ResourceDictionary>
      <Color x:Key="Accent">#67c7ff</Color>
      <String x:Key="HeroTitle">Serialized title</String>
    </ResourceDictionary>
  </Canvas.Resources>
  <StackPanel>
    <TextBlock Text="{StaticResource HeroTitle}" Foreground="{StaticResource Accent}" />
  </StackPanel>
</Canvas>
