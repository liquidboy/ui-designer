<Canvas xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Canvas.Resources>
    <ResourceDictionary>
      <Color x:Key="Accent">#ff8157</Color>
      <TextBlock x:Key="SharedLabel" Text="Accent label" Foreground="{StaticResource Accent}" />
    </ResourceDictionary>
  </Canvas.Resources>
  <Border>
    <Border.Child>{StaticResource SharedLabel}</Border.Child>
  </Border>
</Canvas>
