<StackPanel xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel.Resources>
    <ResourceDictionary>
      <Color x:Key="Accent">#111111</Color>
    </ResourceDictionary>
  </StackPanel.Resources>
  <TextBlock Text="Outer" Foreground="{StaticResource Accent}" />
  <Border>
    <Border.Resources>
      <ResourceDictionary>
        <Color x:Key="Accent">#222222</Color>
      </ResourceDictionary>
    </Border.Resources>
    <TextBlock Text="Inner" Foreground="{StaticResource Accent}" />
  </Border>
</StackPanel>
