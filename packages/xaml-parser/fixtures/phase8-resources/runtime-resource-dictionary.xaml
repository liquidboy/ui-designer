<Canvas xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Canvas.Resources>
    <ResourceDictionary>
      <Color x:Key="Accent">#67c7ff</Color>
      <Number x:Key="HeroSize" Value="24" />
      <String x:Key="HeroTitle">Resource title</String>
    </ResourceDictionary>
  </Canvas.Resources>
  <TextBlock Text="{StaticResource HeroTitle}" Foreground="{StaticResource Accent}" FontSize="{StaticResource HeroSize}" />
</Canvas>
