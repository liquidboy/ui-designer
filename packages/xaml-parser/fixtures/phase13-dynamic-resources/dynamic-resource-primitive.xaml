<Canvas xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Canvas.Resources>
    <ResourceDictionary>
      <Color x:Key="Accent">#111111</Color>
      <Color x:Key="StaticAccent">#222222</Color>
    </ResourceDictionary>
  </Canvas.Resources>
  <StackPanel>
    <TextBlock Text="Dynamic" Foreground="{DynamicResource Accent}" />
    <TextBlock Text="Static" Foreground="{StaticResource StaticAccent}" />
  </StackPanel>
</Canvas>
